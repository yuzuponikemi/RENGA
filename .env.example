# Azure AI Foundry — OpenAI 互換エンドポイント (openai/v1)
AZURE_FOUNDRY_ENDPOINT=https://<resource>.openai.azure.com/openai/v1
AZURE_FOUNDRY_API_KEY=<Foundry の API キー>
AZURE_FOUNDRY_DEPLOYMENT=<デプロイ名 例: DeepSeek-V4-Flash>

# ログソース（任意・未設定なら data/synthetic_logs.json）
# 単一ソース:
#   LOG_SOURCE=claude_code                       — Claude Code セッションログ全件
#   LOG_SOURCE=claude_code+/path1:/path2         — 複数ディレクトリ
#   LOG_SOURCE=claude_code@RENGA                 — プロジェクト名フィルタ
#   LOG_SOURCE=vscode_copilot                    — VSCode の GitHub Copilot Chat ログ全件
#   LOG_SOURCE=vscode_copilot@infoseeker         — ワークスペース名フィルタ
#   LOG_SOURCE=vscode_copilot+/custom/workspaceStorage
# マルチソース (カンマ区切り):
#   LOG_SOURCE=claude_code,vscode_copilot
# LOG_SOURCE=

# 貢献者識別子（任意）
# 未設定の場合は git config user.email を SHA-256 で 8 桁に圧縮して使う。
# 複数 PC で同じ git email を使っていれば自動的に同一人物として認識される。
# 組織展開では明示的に設定推奨（例: USER_ID=alice）。
# USER_ID=

# 動作モード切替
# personal (既定): catalog/skills.json を読み書きする個人完結モード
# org            : Cosmos DB から read、usage_events を append する組織連携モード
# RENGA_MODE=personal

# 組織モード (RENGA_MODE=org) のときに必要 — uv sync --extra org で azure-cosmos が入る
# COSMOS_ENDPOINT=https://<account>.documents.azure.com:443/
# COSMOS_KEY=<read-only key を推奨>
# COSMOS_DB=skill-hub
# USER_HANDLE=#A1
# RENGA_CLIENT_CONTEXT=mcp
